{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "site_title": {
      "type": "string"
    },
    "site_description": {
      "type": "string"
    },
    "artist_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email",
      "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
    },
    "instagram_url": {
      "type": "string",
      "format": "uri"
    },
    "facebook_url": {
      "type": "string",
      "format": "uri"
    },
    "logo": {
      "type": "string"
    },
    "og_image": {
      "type": "string"
    },
    "media_base_url": {
      "default": "https://media.alenam.art",
      "type": "string",
      "format": "uri"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "site_title",
    "site_description",
    "artist_name",
    "email"
  ]
}