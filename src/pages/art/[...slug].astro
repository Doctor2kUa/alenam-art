if (!post) return new Response(null, { status: 404 });
---

<BaseLayout title={post.title}>
  <article class="pt-24 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12">
        <h1 class="text-3xl md:text-5xl font-display leading-tight mb-4">{post.title}</h1>
        <time class="text-sm text-secondary">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </header>

      <div class="wp-content prose prose-lg max-w-none" set:html={post.content} />

      {post.images && post.images.length > 0 && (
        <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {post.images.map((img) => (
            <figure class="m-0">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-auto rounded-sm"
                loading="lazy"
              />
            </figure>
          ))}
        </div>
      )}

      <nav class="mt-16 pt-8 border-t border-gray-200">
        <div class="flex justify-between items-center">
          {post.prevSlug ? (
            <a href={`/art/${post.prevSlug}/`} class="text-sm text-secondary hover:text-primary transition-colors max-w-[45%]">
              <span class="block text-xs uppercase tracking-wider mb-1">← Prev</span>
              <span class="font-display text-base">{post.prevTitle}</span>
            </a>
          ) : <div />}
          {post.nextSlug ? (
            <a href={`/art/${post.nextSlug}/`} class="text-sm text-secondary hover:text-primary transition-colors text-right max-w-[45%]">
              <span class="block text-xs uppercase tracking-wider mb-1">Next →</span>
              <span class="font-display text-base">{post.nextTitle}</span>
            </a>
          ) : <div />}
        </div>
      </nav>

      <div class="mt-8 text-center">
        <a href="/art/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">← Back to Art</a>
      </div>
    </div>
  </article>
</BaseLayout>
