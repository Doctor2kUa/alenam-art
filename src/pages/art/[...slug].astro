---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const posts = [
    { slug: 'amazing-evening-amazing-place-amazing-people' },
    { slug: 'a-presentation-of-the-art-collection-confessions-should-be-better-planned-by-alena-martsyanava' },
    { slug: 'confessions-should-be-better-planned-1-0-in-warsaw' },
    { slug: 'flora' },
    { slug: 'big-city-life' },
    { slug: 'bits-and-pieces' },
    { slug: 'little-pleasures' },
    { slug: 'at-the-seaside' },
    { slug: 'mind-games' },
    { slug: 'confessions-should-be-better-planned' },
    { slug: 'taking-part-in-contro-la-violenza-sulle-donne-expo' },
    { slug: 'auction-in-wroclaw-poland' },
    { slug: 'interpretation-of-moments-boys-vs-girls' },
    { slug: 'the-dream-on-expo' },
    { slug: 'the-35-expo' },
    { slug: 'сhaotic-still-life' },
    { slug: 'first-expo' },
  ];
  return posts.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const allPosts = {
  'amazing-evening-amazing-place-amazing-people': {
    title: 'Amazing evening, amazing place, amazing people!', date: '2025-06-01',
    content: `<p>Thanks a million to @sante_praha for hosting my art collection "Confessions should be better planned", to @wine.you.prague for supporting my idea, to @trambitskaya_photo for being my dearest content maker!</p><p>The artworks are in Prague for a few months in summer, so don't miss the opportunity to see them, buy them and support the special needs children via @burrenchernobyl!</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/06/alena.mp4', alt: 'Prague exhibition' }], prevSlug: 'a-presentation-of-the-art-collection-confessions-should-be-better-planned-by-alena-martsyanava', prevTitle: 'A presentation of the art collection',
  },
  'a-presentation-of-the-art-collection-confessions-should-be-better-planned-by-alena-martsyanava': {
    title: 'A presentation of the art collection "Confessions Should Be Better Planned"', date: '2025-05-07',
    content: `<p>On the 23rd of May, SANTE in Prague is welcoming the audience for a special event: A presentation of the art collection "Confessions Should Be Better Planned" by Alena Martsyanava.</p><p><strong>The concept: buy art and help people.</strong></p><p>All artworks are for sale, and ⅓ of the money will go to support children in institutions via the <a href="https://burrenchernobyl.ie/" target="_blank" rel="noopener noreferrer">Burren Chernobyl Project</a>.</p><p><strong>Date:</strong> 23 May 2025<br><strong>Place:</strong> SANTE, Prague<br><strong>Time:</strong> 18.00<br><strong>Entrance:</strong> FREE</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/05/alena.avif', alt: 'Prague presentation' }], prevSlug: 'confessions-should-be-better-planned-1-0-in-warsaw', prevTitle: 'Confessions 1.0 in Warsaw', nextSlug: 'amazing-evening-amazing-place-amazing-people', nextTitle: 'Amazing evening',
  },
  'confessions-should-be-better-planned-1-0-in-warsaw': {
    title: 'Confessions should be better planned 1.0 in Warsaw', date: '2025-03-02',
    content: `<p>On February 16, 2025, the art-beauty shop ALAR in Warsaw launched the first expo. Only 8 works were exhibited. A closed event with the presentation was a real success.</p>`,
    images: [
      { src: 'https://alenam.art/wp-content/uploads/2025/03/photo_5334917533247075315_y-1.avif', alt: 'Warsaw' },
      { src: 'https://alenam.art/wp-content/uploads/2025/03/photo_5334917533247075316_y-1.avif', alt: 'Warsaw' },
      { src: 'https://alenam.art/wp-content/uploads/2025/03/photo_5334917533247075323_y-1.avif', alt: 'Warsaw' },
      { src: 'https://alenam.art/wp-content/uploads/2025/03/photo_5334917533247075326_y-1.avif', alt: 'Warsaw' },
    ], prevSlug: 'flora', prevTitle: 'Flora', nextSlug: 'a-presentation-of-the-art-collection-confessions-should-be-better-planned-by-alena-martsyanava', nextTitle: 'A presentation of the art collection',
  },
  'flora': {
    title: 'Flora', date: '2025-02-26',
    content: `<p>The timeless bond between girls and flowers inspires this collection. The fleeting beauty of blooms finds eternal life on canvas.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/02/5332760235598803087.avif', alt: 'Flora' }], prevSlug: 'big-city-life', prevTitle: 'Big City Life', nextSlug: 'confessions-should-be-better-planned-1-0-in-warsaw', nextTitle: 'Confessions 1.0 in Warsaw',
  },
  'big-city-life': {
    title: 'Big City Life', date: '2025-01-20',
    content: `<p>A tribute to the cities that have shaped my journey. Each image captures a fleeting moment, a memory etched into the soul.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/IMG_5833.avif', alt: 'Big City Life' }], prevSlug: 'bits-and-pieces', prevTitle: 'Bits and Pieces', nextSlug: 'flora', nextTitle: 'Flora',
  },
  'bits-and-pieces': {
    title: 'Bits and Pieces', date: '2025-01-18',
    content: `<p>Beauty exists in everything — it is all about learning to see it. Small details and grand impressions draw us in.</p>`,
