---

<BaseLayout title={col.title}>
  <article class="pt-24 pb-20">
    <!-- Collection Hero -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <a href="/art/" class="text-sm text-secondary hover:text-primary transition-colors mb-4 inline-block">← Back to Collections</a>
      <h1 class="text-3xl md:text-5xl font-display leading-tight mb-2">{col.title}</h1>
      <p class="text-lg text-secondary font-display mb-4">{col.subtitle}</p>
      <p className="text-secondary leading-relaxed">{col.description}</p>
    </div>

    {/* Available Works Banner */}
    {col.hasAvailableBanner && (
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
        <div class="bg-accent/10 border border-accent/20 rounded-sm p-4 text-center">
          <p class="text-sm">Selected works from this collection are available for purchase.</p>
          <a href="/contact/" class="inline-block mt-2 text-sm font-medium text-accent hover:text-accent/80">Ask about the collection →</a>
        </div>
      </div>
    )}

    <!-- Filters -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
      <div class="flex flex-wrap gap-2 artwork-filters">
        <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-primary text-white rounded-sm" data-filter="all">All</button>
        <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="available">Available</button>
        <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="sold">Sold</button>
        <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="private-collection">Private collection</button>
      </div>
    </div>

    <!-- Empty state -->
    <div id="artwork-empty" class="hidden text-center py-16">
      <p class="text-secondary">No works in this category right now.</p>
    </div>

    <!-- Artwork Grid -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid artwork-grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {col.artworks.map((artwork) => (
          <div class="group artwork-card" data-status={artwork.status.toLowerCase().replace(' ', '-')}>
            <figure class="m-0 mb-3">
              <a href={`/art/${slug}/${artwork.slug}/`} class="block">
                <img
                  src={artwork.image}
                  alt={`${artwork.name}, ${artwork.technique} by Alena Mart`}
                  class="w-full h-auto rounded-sm group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              </a>
            </figure>
            <h3 class="font-display text-base mb-1">
              <a href={`/art/${slug}/${artwork.slug}/`} class="hover:text-accent transition-colors">{artwork.name}</a>
            </h3>
            <p class="text-xs text-secondary">{artwork.technique} · {artwork.size} · {artwork.year}</p>
            <div class="mt-2 flex items-center justify-between">
              {artwork.status === 'Available' ? (
                <span class="text-xs font-medium text-accent">Available</span>
              ) : artwork.status === 'Sold' ? (
                <span class="text-xs text-gray-400">Sold</span>
              ) : (
                <span class="text-xs text-gray-400">{artwork.status}</span>
              )}
              {artwork.cta && (
                <a href={`/contact/?interest=buy&artwork=${encodeURIComponent(artwork.name)}&collection=${encodeURIComponent(col.title)}`} class="text-xs font-medium text-accent hover:text-accent/80">{artwork.cta}</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* CTA */}
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-16 text-center">
      <p class="text-secondary mb-4">{col.cta}</p>
      <a href="/contact/" class="inline-block bg-primary text-white px-6 py-3 text-sm uppercase tracking-wider font-medium hover:bg-primary/90 transition-colors">
        Contact the Artist
      </a>
    </div>

    {/* Navigation between collections */}
    <nav class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-16 pt-8 border-t border-gray-200">
      <div class="flex justify-between items-center gap-4">
        {col.prevSlug ? (
          <a href={`/art/${col.prevSlug}/`} class="text-sm hover:text-accent transition-colors max-w-[40%]">
            <span class="block text-xs uppercase tracking-wider text-secondary mb-1">← Previous</span>
            <span class="font-display text-base text-primary">{col.prevTitle}</span>
          </a>
        ) : <div class="max-w-[40%]" />}
        <a href="/art/" class="text-xs text-secondary hover:text-primary transition-colors flex-shrink-0">All Collections</a>
        {col.nextSlug ? (
          <a href={`/art/${col.nextSlug}/`} class="text-sm hover:text-accent transition-colors max-w-[40%] text-right">
            <span class="block text-xs uppercase tracking-wider text-secondary mb-1">Next →</span>
            <span class="font-display text-base text-primary">{col.nextTitle}</span>
          </a>
        ) : <div class="max-w-[40%]" />}
      </div>
    </nav>
  </article>

  <script>
    (function() {
      var filterContainer = document.querySelector('.artwork-filters');
      if (!filterContainer) return;
      var buttons = filterContainer.querySelectorAll('.filter-btn');
      var cards = document.querySelectorAll('.artwork-card');
      var emptyMsg = document.getElementById('artwork-empty');

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var filter = btn.getAttribute('data-filter');

          // Update active state
          buttons.forEach(function(b) {
            b.classList.remove('bg-primary', 'text-white');
            b.classList.add('bg-gray-100', 'text-secondary');
          });
          btn.classList.remove('bg-gray-100', 'text-secondary');
          btn.classList.add('bg-primary', 'text-white');

          // Filter cards
          var visible = 0;
          cards.forEach(function(card) {
            var status = card.getAttribute('data-status');
            if (filter === 'all' || status === filter) {
              card.style.display = '';
              visible++;
            } else {
              card.style.display = 'none';
            }
          });

          // Empty state
          if (emptyMsg) {
            emptyMsg.style.display = visible === 0 ? 'block' : 'none';
          }
        });
      });
    })();
  </script>
</BaseLayout>
