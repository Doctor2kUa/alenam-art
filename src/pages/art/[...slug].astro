  },
  'mind-games': {
    title: 'Mind Games', date: '2025-01-03',
    content: `<p>A series of sketches filled with symbols, hidden meanings, and puzzles waiting to be solved.</p><ul><li><strong>Night dweller</strong> — Paper, pencil, A3. July 2021</li><li><strong>Flowers never die</strong> — Paper, pencil, A3. April 2021</li><li><strong>A drop</strong> — Paper, acryl, coal, pencil, A3. November 2021</li><li><strong>My heart's stopped</strong> — Paper, gouache, pencil, A3. July 2021</li><li><strong>Game of chairs</strong> — Paper, pencil, gouache, A3. July 2021</li><li><strong>Fusion</strong> — Paper, pencil, A3. April 2021</li><li><strong>Oops, I spilt the paint</strong> — Gouache, pencil, paper, A3. July 2021</li></ul>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/IMG_5794.avif', alt: 'Mind Games' }], prevSlug: 'confessions-should-be-better-planned', prevTitle: 'Confessions should be better planned', nextSlug: 'at-the-seaside', nextTitle: 'At the Seaside',
  },
  'confessions-should-be-better-planned': {
    title: 'Confessions should be better planned', date: '2025-01-03',
    content: `<p>A series exploring the raw and unfiltered nature of expression. Hidden truths revealed, dreams concealed behind masks, and words left unspoken.</p><ul><li><strong>A thought</strong> — Acryl, canvas. 100×70cm. September 2021</li><li><strong>No more stories</strong> — Acrylic on canvas. 100×100cm. October 2021</li><li><strong>A red stone</strong> — Acrylic on canvas. 120×100cm. November 2021</li><li><strong>Connection</strong> — Acrylic on canvas. 50×60cm. October 2021</li><li><strong>Gone</strong> — Acryl on canvas, 40×60cm. February 2022 — Available</li><li><strong>The darkest side</strong> — Acryl on canvas, 70×90cm. December 2022</li><li><strong>The tune</strong> — Acrylics on canvas, 50×70cm — Available</li><li><strong>Disconnect</strong> — Acrylic on canvas, 50×70cm. March 2024 — Available</li><li><strong>Apple</strong> — Acrylic on canvas, 100×70cm. May 2022 — Available</li><li><strong>Angie</strong> — Acrylic on canvas, 120×120cm. April 2022 — Available</li><li><strong>Time to rest</strong> — Acrylic on canvas, 100×70cm. January 2024 — Available</li><li><strong>What have I done?</strong> — Acrylic on canvas, 70×100cm. January 2025 — Available</li></ul><p>This series delves into the intricate and often chaotic realm of human expression.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/IMG_5566.avif', alt: 'Confessions' }], prevSlug: 'taking-part-in-contro-la-violenza-sulle-donne-expo', prevTitle: 'Taking part in "Contro la Violenza" expo', nextSlug: 'mind-games', nextTitle: 'Mind Games',
  },
  'taking-part-in-contro-la-violenza-sulle-donne-expo': {
    title: 'Taking part in "Contro la Violenza sulle Donne" expo', date: '2025-01-03',
    content: `<p>So proud to have had a chance of participating in the event raising awareness of the domestic violence towards women in Italy. My artwork "oops I spilt the paint" drew a lot of attention.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/photo_5458821030429715645_x-1.jpg', alt: 'Violenza expo' }], prevSlug: 'auction-in-wroclaw-poland', prevTitle: 'Auction in Wroclaw', nextSlug: 'confessions-should-be-better-planned', nextTitle: 'Confessions should be better planned',
  },
  'auction-in-wroclaw-poland': {
    title: 'Auction in Wroclaw, Poland', date: '2025-01-03',
