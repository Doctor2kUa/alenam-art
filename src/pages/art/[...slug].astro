    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/photo_5458821030429715635_y-1.jpg', alt: 'Wroclaw auction' }], prevSlug: 'interpretation-of-moments-boys-vs-girls', prevTitle: 'Interpretation of moments', nextSlug: 'taking-part-in-contro-la-violenza-sulle-donne-expo', nextTitle: 'Taking part in "Contro la Violenza" expo',
  },
  'interpretation-of-moments-boys-vs-girls': {
    title: 'Interpretation of moments: boys vs girls', date: '2024-12-15',
    content: `<p>Join-forces-expo with Eugene Buzouski from Minsk. The expo took place in Beetlejuice cafe in December 2019 and lasted over 2 months.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/photo_5458821030429715608_y.jpg', alt: 'Boys vs girls' }], prevSlug: 'the-dream-on-expo', prevTitle: 'The "Dream on" Expo', nextSlug: 'auction-in-wroclaw-poland', nextTitle: 'Auction in Wroclaw',
  },
  'the-dream-on-expo': {
    title: 'The "Dream on" Expo', date: '2024-12-10',
    content: `<p>The first time Alena introduced a new young talent — Anna Trusevich from Minsk. In October 2019 the artworks were presented.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/photo_5458821030429715599_y.jpg', alt: 'Dream on Expo' }], prevSlug: 'the-35-expo', prevTitle: 'The "35" Expo', nextSlug: 'interpretation-of-moments-boys-vs-girls', nextTitle: 'Interpretation of moments',
  },
  'the-35-expo': {
    title: 'The "35" Expo', date: '2024-12-05',
    content: `<p>Dedicated to Alena's 35th anniversary. The Stary Olsa band performed. The expo contained exactly 35 artworks and was available the whole April 2018.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/photo_5458821030429715570_y.jpg', alt: 'The 35 Expo' }], prevSlug: 'сhaotic-still-life', prevTitle: 'Сhaotic still-life', nextSlug: 'the-dream-on-expo', nextTitle: 'The "Dream on" Expo',
  },
  'сhaotic-still-life': {
    title: 'Сhaotic still-life', date: '2024-11-27',
    content: `<p>Took place in autumn 2014 while Alena was expecting her baby. About 25 new works of various techniques: from oil painting to sketches and Grattage.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/photo_5458821030429715564_x.jpg', alt: 'Сhaotic still-life' }], prevSlug: 'first-expo', prevTitle: 'First Expo', nextSlug: 'the-35-expo', nextTitle: 'The "35" Expo',
  },
  'first-expo': {
    title: 'First Expo', date: '2024-11-27',
    content: `<p>First Alena's Expo happened back in 2013 with 30 artworks. A local rock band performed at the opening. It lasted 30 days and attracted more than a thousand visitors.</p>`,
    images: [{ src: 'https://alenam.art/wp-content/uploads/2025/01/IMG_9008-2_resized.jpg', alt: 'First Expo' }], nextSlug: 'сhaotic-still-life', nextTitle: 'Сhaotic still-life',
  },
};

const post = allPosts[slug];
if (!post) return new Response(null, { status: 404 });
---

<BaseLayout title={post.title}>
  <article class="pt-24 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12">
        <p class="text-sm font-medium uppercase tracking-[0.3em] text-secondary mb-4">Art</p>
        <h1 class="text-3xl md:text-5xl font-display leading-tight mb-4">{post.title}</h1>
        <time class="text-sm text-secondary">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </header>
      <div class="wp-content prose prose-lg max-w-none" set:html={post.content} />
      {post.images && post.images.length > 0 && (
        <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
          {post.images.map((img) => (<figure class="m-0"><img src={img.src} alt={img.alt} class="w-full h-auto rounded-sm" loading="lazy" /></figure>))}
        </div>
      )}
      <nav class="mt-16 pt-8 border-t border-gray-200">
        <div class="flex justify-between items-center">
          {post.prevSlug ? (<a href={`/art/${post.prevSlug}/`} class="text-sm text-secondary hover:text-primary transition-colors max-w-[45%]"><span class="block text-xs uppercase tracking-wider mb-1">← Prev</span><span class="font-display text-base">{post.prevTitle}</span></a>) : <div />}
          {post.nextSlug ? (<a href={`/art/${post.nextSlug}/`} class="text-sm text-secondary hover:text-primary transition-colors text-right max-w-[45%]"><span class="block text-xs uppercase tracking-wider mb-1">Next →</span><span class="font-display text-base">{post.nextTitle}</span></a>) : <div />}
        </div>
      </nav>
      <div class="mt-8 text-center"><a href="/art/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">← Back to Art</a></div>
    </div>
  </article>
</BaseLayout>
