        { slug: 'little-pleasure-iii', name: 'Little pleasure III', technique: 'Pastel, paper', size: 'A4', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5797-824x1024.avif' },
        { slug: 'little-pleasure-iv', name: 'Little pleasure IV', technique: 'Pastel, paper', size: 'A4', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5798-818x1024.avif' },
        { slug: 'little-pleasure-v', name: 'Little pleasure V', technique: 'Pastel, paper', size: 'A4', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5799-1024x764.avif' },
        { slug: 'little-pleasure-vi', name: 'Little pleasure VI', technique: 'Pastel, paper', size: 'A4', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5800-1024x719.avif' },
        { slug: 'little-pleasure-vii', name: 'Little pleasure VII', technique: 'Pastel, paper', size: 'A4', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5801-1024x679.avif' },
        { slug: 'little-pleasure-viii', name: 'Little pleasure VIII', technique: 'Pastel, paper', size: 'A4', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5802-820x1024.avif' },
        { slug: 'little-pleasure-ix', name: 'Little pleasure IX', technique: 'Pastel, paper', size: 'A4', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5803-821x1024.avif' },
        { slug: 'little-pleasure-x', name: 'Little pleasure X', technique: 'Pastel, paper', size: 'A4', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5804-820x1024.avif' },
      ],
    },
  };

  const paths = [];
  for (const [colSlug, col] of Object.entries(collections)) {
    for (const artwork of col.artworks) {
      paths.push({
        params: { collection: colSlug, work: artwork.slug },
        props: { artwork, collection: col },
      });
    }
  }
  return paths;
}

const { artwork, collection } = Astro.props;
---

<BaseLayout title={`${artwork.name} — ${collection.title}`}>
  <article class="pt-24 pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Back link -->
      <a href={`/art/${Astro.params.collection}/`} class="text-sm text-secondary hover:text-primary transition-colors mb-8 inline-block">
        ← Back to {collection.title}
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Image -->
        <div>
          <img
            src={artwork.image}
            alt={artwork.name}
            class="w-full h-auto rounded-sm"
          />
        </div>

        <!-- Details -->
        <div class="flex flex-col justify-center">
          <h1 class="text-3xl md:text-4xl font-display mb-4">{artwork.name}</h1>
          <p class="text-secondary mb-2">{artwork.technique}</p>
          <p class="text-secondary mb-2">{artwork.size}</p>
          <p class="text-secondary mb-6">{artwork.year}</p>

          {artwork.status === 'Available' ? (
            <div class="mb-6">
              <span class="inline-block bg-accent/10 text-accent px-3 py-1 text-sm font-medium rounded-sm">Available</span>
            </div>
          ) : artwork.status === 'Sold' ? (
            <div class="mb-6">
              <span class="inline-block bg-gray-100 text-gray-400 px-3 py-1 text-sm rounded-sm">Sold</span>
            </div>
          ) : (
            <div class="mb-6">
              <span class="inline-block bg-gray-100 text-gray-400 px-3 py-1 text-sm rounded-sm">{artwork.status}</span>
            </div>
          )}

          <p class="text-sm text-secondary mb-6">
            Part of the <a href={`/art/${Astro.params.collection}/`} class="text-accent hover:text-accent/80">{collection.title}</a> collection.
          </p>

          {artwork.status === 'Available' ? (
            <div class="space-y-3">
              <a href="/contact/" class="block w-full bg-primary text-white px-6 py-3 text-sm uppercase tracking-wider font-medium text-center hover:bg-primary/90 transition-colors">
                Request price
              </a>
              <a href="/contact/" class="block w-full border border-primary text-primary px-6 py-3 text-sm uppercase tracking-wider font-medium text-center hover:bg-primary/5 transition-colors">
                Ask about this work
              </a>
            </div>
          ) : (
            <a href="/contact/" class="block w-full border border-gray-200 text-secondary px-6 py-3 text-sm uppercase tracking-wider font-medium text-center hover:bg-gray-50 transition-colors">
              Ask about similar work
            </a>
          )}
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
