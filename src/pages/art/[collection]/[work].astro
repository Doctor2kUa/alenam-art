---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const base = 'https://alenam.art/wp-content/uploads/';

  const collections = {
    'confessions-should-be-better-planned': {
      title: 'Confessions should be better planned',
      artworks: [
        { slug: 'gone', name: 'Gone', technique: 'Acrylic on canvas', size: '40×60 cm', year: '2022', status: 'Available', image: base + '2025/01/IMG_5567-669x1024.avif' },
        { slug: 'disconnect', name: 'Disconnect', technique: 'Acrylic on canvas', size: '50×70 cm', year: '2024', status: 'Available', image: base + '2025/01/IMG_5560-1012x1024.avif' },
        { slug: 'apple', name: 'Apple', technique: 'Acrylic on canvas', size: '100×70 cm', year: '2022', status: 'Available', image: base + '2025/01/IMG_5556-786x1024.avif' },
        { slug: 'angie', name: 'Angie', technique: 'Acrylic on canvas', size: '120×120 cm', year: '2022', status: 'Available', image: base + '2025/01/IMG_5562-1024x1024.avif' },
        { slug: 'time-to-rest', name: 'Time to rest', technique: 'Acrylic on canvas', size: '100×70 cm', year: '2024', status: 'Available', image: base + '2025/01/Untitled-1-819x1024.avif' },
        { slug: 'what-have-i-done', name: 'What have I done?', technique: 'Acrylic on canvas', size: '70×100 cm', year: '2025', status: 'Available', image: base + '2025/02/5330074966210769581-779x1024.avif' },
        { slug: 'the-tune', name: 'The tune', technique: 'Acrylic on canvas', size: '50×70 cm', year: 'Available', image: base + '2025/01/IMG_5552-1024x733.avif' },
        { slug: 'a-thought', name: 'A thought', technique: 'Acrylic on canvas', size: '100×70 cm', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5550-827x1024.avif' },
        { slug: 'no-more-stories', name: 'No more stories', technique: 'Acrylic on canvas', size: '100×100 cm', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5558-1024x1019.avif' },
        { slug: 'a-red-stone', name: 'A red stone', technique: 'Acrylic on canvas', size: '120×100 cm', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5571-818x1024.avif' },
        { slug: 'connection', name: 'Connection', technique: 'Acrylic on canvas', size: '50×60 cm', year: '2021', status: 'Private collection', image: base + '2025/01/IMG_5566-787x1024.avif' },
        { slug: 'the-darkest-side', name: 'The darkest side', technique: 'Acrylic on canvas', size: '70×90 cm', year: '2022', status: 'Private collection', image: base + '2025/01/IMG_5563-786x1024.avif' },
      ],
    },
    'big-city-life': {
      title: 'Big City Life',
      artworks: [
        { slug: 'april-in-minsk', name: 'April in Minsk', technique: 'Oil on canvas', size: '60×60 cm', year: '2013', status: 'Available', image: base + '2025/01/IMG_5829-1024x838.avif' },
        { slug: 'madam-tussauds-in-ny', name: 'Madam Tussauds in NY', technique: 'Oil on canvas', size: '50×70 cm', year: '2013', status: 'Available', image: base + '2025/02/1-821x1024.avif' },
        { slug: 'the-tram', name: 'The Tram', technique: 'Oil on canvas', size: '90×60 cm', year: '2013', status: 'Private collection', image: base + '2025/02/tram-1024x679.avif' },
        { slug: 'lisbon-tram', name: 'Lisbon Tram', technique: 'Oil on canvas', size: '50×70 cm', year: '2013', status: 'Sold', image: base + '2025/01/IMG_5826-773x1024.avif' },
        { slug: 'train-in-the-rain', name: 'Train in the rain', technique: 'Oil on canvas', size: '40×60 cm', year: '2016', status: 'Sold', image: base + '2025/01/IMG_5827-1024x764.avif' },
        { slug: 'magnetic-times-square', name: 'Magnetic Times Square', technique: 'Oil on canvas', size: '75×100 cm', year: '2013', status: 'Private collection', image: base + '2025/01/IMG_5828-1024x1014.avif' },
        { slug: 'rainy-eiffel', name: 'Rainy Eiffel', technique: 'Oil on canvas', size: '50×60 cm', year: '2013', status: 'Private collection', image: base + '2025/01/IMG_5830-1024x836.avif' },
