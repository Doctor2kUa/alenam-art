        { slug: 'the-city-of-love', name: 'The city of love', technique: 'Oil on canvas', size: '100×70 cm', year: '2014', status: 'Private collection', image: base + '2025/02/5330074966210769603-1024x771.avif' },
      ],
    },
    'flora': {
      title: 'Flora',
      artworks: [
        { slug: 'flora-i', name: 'Flora I', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Available', image: base + '2025/02/5332760235598803087-1024x674.avif' },
        { slug: 'flora-viii', name: 'Flora VIII', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Available', image: base + '2025/02/5330510415765039716-1024x1014.avif' },
        { slug: 'flora-ii', name: 'Flora II', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Private collection', image: base + '2025/02/5330074966210769624-406x1024.avif' },
        { slug: 'flora-iii', name: 'Flora III', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Private collection', image: base + '2025/02/5330074966210769625-1024x402.avif' },
        { slug: 'flora-iv', name: 'Flora IV', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Private collection', image: base + '2025/02/5330074966210769626-1024x1024.avif' },
        { slug: 'flora-v', name: 'Flora V', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Private collection', image: base + '2025/02/5330074966210769627-1024x751.avif' },
        { slug: 'flora-vi', name: 'Flora VI', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Private collection', image: base + '2025/02/5330074966210769628-1024x754.avif' },
        { slug: 'flora-vii', name: 'Flora VII', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Private collection', image: base + '2025/02/5330074966210769629-769x1024.avif' },
        { slug: 'flora-ix', name: 'Flora IX', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', status: 'Private collection', image: base + '2025/02/5330510415765039717-874x1024.avif' },
