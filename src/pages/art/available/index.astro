<BaseLayout title={title} description={description}>
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-display mb-6">{title}</h1>
    <p class="text-lg text-secondary leading-relaxed mb-4">
      Complete catalog of artworks by Alena Martsyanava. Browse all works across collections.
    </p>
    <p class="text-sm text-secondary">
      Original artworks · Direct contact with the artist · Shipping details on request · Replicas and commissions available
    </p>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto pb-20">
    <div class="flex flex-wrap gap-2 mb-12 available-filters">
      <button class="filter-btn active px-3 py-1 text-xs uppercase tracking-wider bg-primary text-white rounded-sm" data-filter="all" data-group="status">All</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="Available" data-group="status">Available</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="Sold" data-group="status">Sold</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="Private collection" data-group="status">Private collection</button>
    </div>

    <div class="flex flex-wrap gap-2 mb-8 available-filters">
      <button class="filter-btn active px-3 py-1 text-xs uppercase tracking-wider bg-primary text-white rounded-sm" data-filter="all" data-group="collection">All collections</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="big-city-life" data-group="collection">Big City Life</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="bits-and-pieces" data-group="collection">Bits and Pieces</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="little-pleasures" data-group="collection">Little Pleasures</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="at-the-seaside" data-group="collection">At the Seaside</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="mind-games" data-group="collection">Mind Games</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="confessions-should-be-better-planned" data-group="collection">Confessions</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="flora" data-group="collection">Flora</button>
    </div>

    <div id="available-empty" class="hidden text-center py-16">
      <p class="text-secondary">No works in this category right now.</p>
    </div>

    <div class="grid artwork-grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {availableWorks.map((work) => (
        <div class="group available-card" data-status={work.status.toLowerCase().replace(' ', '-')} data-type={work.type} data-format={work.format} data-collection={work.collectionSlug}>
          <figure class="m-0 mb-3">
            <img
              src={work.image}
              alt={`${work.name}, ${work.technique} by Alena Mart from the ${work.collection} collection`}
              class="w-full h-auto rounded-sm group-hover:opacity-90 transition-opacity"
              loading="lazy"
            />
          </figure>
          <h3 class="font-display text-base mb-1">{work.name}</h3>
          <p class="text-xs text-secondary">{work.technique} · {work.size} · {work.year}</p>
          <p class="text-xs text-secondary mt-1">
            <a href={`/art/${work.collectionSlug}/`} class="hover:text-accent transition-colors">{work.collection}</a>
          </p>
          {work.status === 'Available' ? (
            <p class="mt-2 text-xs font-medium text-accent">Available</p>
          ) : work.status === 'Sold' ? (
            <p class="mt-2 text-xs text-gray-400">Sold</p>
          ) : (
            <p class="mt-2 text-xs text-gray-400">{work.status}</p>
          )}
          {work.status === 'Available' && (
            <a href={`/contact/?interest=buy&artwork=${encodeURIComponent(work.name)}&collection=${encodeURIComponent(work.collection)}`} class="block mt-3 text-xs font-medium text-accent hover:text-accent/80">
              Request price →
            </a>
          )}
        </div>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-gray-200 text-center">
      <p class="text-secondary mb-4">Looking for something specific?</p>
      <a href="/contact/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">
        Contact the Artist
      </a>
    </div>
  </section>

  <script>
    (function() {
      var filters = {
        status: 'all',
        collection: 'all'
      };
      var cards = document.querySelectorAll('.available-card');
      var emptyMsg = document.getElementById('available-empty');
      var buttons = document.querySelectorAll('.available-filters .filter-btn');

      function applyFilters() {
        var visible = 0;
        cards.forEach(function(card) {
          var matchStatus = filters.status === 'all' || card.getAttribute('data-status') === filters.status;
          var matchCollection = filters.collection === 'all' || card.getAttribute('data-collection') === filters.collection;
          if (matchStatus && matchCollection) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });
        if (emptyMsg) {
          emptyMsg.style.display = visible === 0 ? 'block' : 'none';
        }
      }

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var group = btn.getAttribute('data-group');
          var filter = btn.getAttribute('data-filter');

          buttons.forEach(function(b) {
            if (b.getAttribute('data-group') === group) {
              b.classList.remove('bg-primary', 'text-white');
              b.classList.add('bg-gray-100', 'text-secondary');
            }
          });
          btn.classList.remove('bg-gray-100', 'text-secondary');
          btn.classList.add('bg-primary', 'text-white');

          filters[group] = filter;
          applyFilters();
        });
      });
    })();
  </script>
</BaseLayout>
