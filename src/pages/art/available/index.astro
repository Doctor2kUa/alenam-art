---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { normalizeImageUrl } from '../../../lib/media';

const title = 'Available Works — Alena Mart';
const description = 'Original artworks currently available for purchase by Alena Martsyanava. Browse available paintings and send a request for pricing and shipping details.';

// Load only available works
const allArtworks = await getCollection('artworks');
const availableWorks = allArtworks
  .filter(a => a.data.status === 'Available')
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// Get unique collections for filter
const collections = [...new Set(availableWorks.map(a => a.data.collection))];
---

<BaseLayout title={title} description={description}>
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-display mb-6">{title}</h1>
    <p class="text-lg text-secondary leading-relaxed mb-4">
      Original artworks currently available for purchase. For pricing, shipping and availability, send a request for a specific piece.
    </p>
    <p class="text-sm text-secondary">
      Original works · Direct contact with the artist · Shipping details on request · Replicas and commissions available
    </p>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto pb-20">
    <!-- Filters -->
    <div class="flex flex-wrap gap-2 mb-8 available-filters">
      <button class="filter-btn active px-3 py-1 text-xs uppercase tracking-wider bg-primary text-white rounded-sm" data-filter="all" data-group="collection">All collections</button>
      {collections.map((coll) => (
        <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter={coll} data-group="collection">{coll}</button>
      ))}
    </div>

    <!-- Empty state -->
    <div id="available-empty" class="hidden text-center py-16" role="status" aria-live="polite">
      <p class="text-secondary">No works in this category right now.</p>
    </div>

    <!-- Grid -->
    <div class="grid artwork-grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {availableWorks.map((work) => (
        <div class="group available-card" data-collection={work.data.collection}>
          <figure class="m-0 mb-3">
            <img
              src={normalizeImageUrl(work.data.image || '')}
              alt={work.data.name}
              class="w-full h-auto rounded-sm group-hover:opacity-90 transition-opacity"
              loading="lazy"
            />
          </figure>
          <h3 class="font-display text-base mb-1">{work.data.name}</h3>
          <p class="text-xs text-secondary">{work.data.technique} · {work.data.size} · {work.data.year}</p>
          <p class="text-xs text-secondary mt-1">
            <a href={`/art/${work.data.collection}/`} class="hover:text-accent transition-colors">{work.data.collection}</a>
          </p>
          <p class="mt-2 text-xs font-medium text-accent">Available</p>
          <a href={`/contact/?interest=buy&artwork=${encodeURIComponent(work.data.name)}&collection=${encodeURIComponent(work.data.collection)}`} class="block mt-3 text-xs font-medium text-accent hover:text-accent/80">
            Request price →
          </a>
        </div>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-gray-200 text-center">
      <p class="text-secondary mb-4">Looking for something specific?</p>
      <a href="/contact/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">
        Contact the Artist
      </a>
    </div>
  </section>

  <script>
    (function() {
      var filters = { collection: 'all' };
      var cards = document.querySelectorAll('.available-card');
      var emptyMsg = document.getElementById('available-empty');
      var buttons = document.querySelectorAll('.available-filters .filter-btn');

      function applyFilters() {
        var visible = 0;
        cards.forEach(function(card) {
          var matchCollection = filters.collection === 'all' || card.getAttribute('data-collection') === filters.collection;
          if (matchCollection) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });
        if (emptyMsg) {
          emptyMsg.style.display = visible === 0 ? 'block' : 'none';
        }
      }

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var group = btn.getAttribute('data-group');
          var filter = btn.getAttribute('data-filter');

          buttons.forEach(function(b) {
            if (b.getAttribute('data-group') === group) {
              b.classList.remove('bg-primary', 'text-white');
              b.classList.add('bg-gray-100', 'text-secondary');
            }
          });
          btn.classList.remove('bg-gray-100', 'text-secondary');
          btn.classList.add('bg-primary', 'text-white');

          filters[group] = filter;
          applyFilters();
        });
      });
    })();
  </script>
</BaseLayout>
