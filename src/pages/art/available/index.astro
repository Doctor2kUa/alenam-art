---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = 'Available Works — Alena Mart';
const description = 'Original artworks currently available for purchase by Alena Martsyanava. Browse available paintings and send a request for pricing and shipping details.';
const base = 'https://alenam.art/wp-content/uploads/';

const availableWorks = [
  { name: 'April in Minsk', technique: 'Oil on canvas', size: '60×60 cm', year: 'May 2013', collection: 'Big City Life', collectionSlug: 'big-city-life', type: 'painting', format: 'small', image: base + '2025/01/IMG_5829.avif' },
  { name: 'Madam Tussauds in NY', technique: 'Oil on canvas', size: '50×70 cm', year: 'April 2013', collection: 'Big City Life', collectionSlug: 'big-city-life', type: 'painting', format: 'small', image: base + '2025/02/1.avif' },
  { name: 'Little pleasure I', technique: 'Pastel, paper', size: 'A4', year: '2021', collection: 'Little Pleasures', collectionSlug: 'little-pleasures', type: 'drawing', format: 'small', image: base + '2025/01/IMG_5795.avif' },
  { name: 'Gone', technique: 'Acrylic on canvas', size: '40×60 cm', year: 'February 2022', collection: 'Confessions should be better planned', collectionSlug: 'confessions-should-be-better-planned', type: 'painting', format: 'small', image: base + '2025/01/IMG_5567-scaled.avif' },
  { name: 'The tune', technique: 'Acrylic on canvas', size: '50×70 cm', year: '2022', collection: 'Confessions should be better planned', collectionSlug: 'confessions-should-be-better-planned', type: 'painting', format: 'small', image: base + '2025/01/IMG_5552-scaled.avif' },
  { name: 'Disconnect', technique: 'Acrylic on canvas', size: '50×70 cm', year: 'March 2024', collection: 'Confessions should be better planned', collectionSlug: 'confessions-should-be-better-planned', type: 'painting', format: 'small', image: base + '2025/01/IMG_5560-scaled.avif' },
  { name: 'Apple', technique: 'Acrylic on canvas', size: '100×70 cm', year: 'May 2022', collection: 'Confessions should be better planned', collectionSlug: 'confessions-should-be-better-planned', type: 'painting', format: 'large', image: base + '2025/01/IMG_5556-scaled.avif' },
  { name: 'Angie', technique: 'Acrylic on canvas', size: '120×120 cm', year: 'April 2022', collection: 'Confessions should be better planned', collectionSlug: 'confessions-should-be-better-planned', type: 'painting', format: 'large', image: base + '2025/01/IMG_5562-scaled.avif' },
  { name: 'Time to rest', technique: 'Acrylic on canvas', size: '100×70 cm', year: 'January 2024', collection: 'Confessions should be better planned', collectionSlug: 'confessions-should-be-better-planned', type: 'painting', format: 'large', image: base + '2024/11/Untitled-1.avif' },
  { name: 'What have I done?', technique: 'Acrylic on canvas', size: '70×100 cm', year: 'January 2025', collection: 'Confessions should be better planned', collectionSlug: 'confessions-should-be-better-planned', type: 'painting', format: 'large', image: base + '2025/02/5330074966210769581.avif' },
  { name: 'Flora I', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', collection: 'Flora', collectionSlug: 'flora', type: 'painting', format: 'small', image: base + '2025/02/5332760235598803087.avif' },
  { name: 'Flora VIII', technique: 'Oil on canvas', size: '50×70 cm', year: '2022', collection: 'Flora', collectionSlug: 'flora', type: 'painting', format: 'small', image: base + '2025/02/5330510415765039716.avif' },
];
---

<BaseLayout title={title} description={description}>
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-display mb-6">{title}</h1>
    <p class="text-lg text-secondary leading-relaxed mb-4">
      Original artworks currently available for purchase. For pricing, shipping and availability, send a request for a specific piece.
    </p>
    <p class="text-sm text-secondary">
      Original works · Direct contact with the artist · Shipping details on request · Replicas and commissions available
    </p>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto pb-20">
    <!-- Filters -->
    <div class="flex flex-wrap gap-2 mb-8 available-filters">
      <button class="filter-btn active px-3 py-1 text-xs uppercase tracking-wider bg-primary text-white rounded-sm" data-filter="all" data-group="collection">All collections</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="big-city-life" data-group="collection">Big City Life</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="little-pleasures" data-group="collection">Little Pleasures</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="confessions-should-be-better-planned" data-group="collection">Confessions</button>
      <button class="filter-btn px-3 py-1 text-xs uppercase tracking-wider bg-gray-100 text-secondary hover:bg-gray-200 rounded-sm transition-colors" data-filter="flora" data-group="collection">Flora</button>
    </div>

    <!-- Empty state -->
    <div id="available-empty" class="hidden text-center py-16" role="status" aria-live="polite">
      <p class="text-secondary">No works in this category right now.</p>
    </div>

    <!-- Grid -->
    <div class="grid artwork-grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {availableWorks.map((work) => (
        <div class="group available-card" data-collection={work.collectionSlug}>
          <figure class="m-0 mb-3">
            <img
              src={work.image}
              alt={`${work.name}, ${work.technique} by Alena Mart from the ${work.collection} collection`}
              class="w-full h-auto rounded-sm group-hover:opacity-90 transition-opacity"
              loading="lazy"
            />
          </figure>
          <h3 class="font-display text-base mb-1">{work.name}</h3>
          <p class="text-xs text-secondary">{work.technique} · {work.size} · {work.year}</p>
          <p class="text-xs text-secondary mt-1">
            <a href={`/art/${work.collectionSlug}/`} class="hover:text-accent transition-colors">{work.collection}</a>
          </p>
          <p class="mt-2 text-xs font-medium text-accent">Available</p>
          <a href={`/contact/?interest=buy&artwork=${encodeURIComponent(work.name)}&collection=${encodeURIComponent(work.collection)}`} class="block mt-3 text-xs font-medium text-accent hover:text-accent/80">
            Request price →
          </a>
        </div>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-gray-200 text-center">
      <p class="text-secondary mb-4">Looking for something specific?</p>
      <a href="/contact/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">
        Contact the Artist
      </a>
    </div>
  </section>

  <script>
    (function() {
      var activeFilter = 'all';
      var cards = document.querySelectorAll('.available-card');
      var emptyMsg = document.getElementById('available-empty');
      var buttons = document.querySelectorAll('.available-filters .filter-btn');

      function applyFilter(filter) {
        activeFilter = filter;
        var visible = 0;
        cards.forEach(function(card) {
          if (filter === 'all' || card.getAttribute('data-collection') === filter) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });
        if (emptyMsg) {
          emptyMsg.style.display = visible === 0 ? 'block' : 'none';
        }
      }

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var filter = btn.getAttribute('data-filter');
          buttons.forEach(function(b) {
            b.classList.remove('bg-primary', 'text-white');
            b.classList.add('bg-gray-100', 'text-secondary');
          });
          btn.classList.remove('bg-gray-100', 'text-secondary');
          btn.classList.add('bg-primary', 'text-white');
          applyFilter(filter);
        });
      });

      // Initialize
      applyFilter('all');
    })();
  </script>
</BaseLayout>
