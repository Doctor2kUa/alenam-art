---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { normalizeImageUrl } from '../../lib/media';

const title = 'Art Collections — Alena Mart';
const description = 'Explore the art collections by Alena Martsyanava — from city memories to hidden confessions, symbolic sketches and fragile flowers.';

// Load collections
const allCollections = await getCollection('art_collections');
const collections = allCollections.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// Count artworks per collection
const allArtworks = await getCollection('artworks');
const collectionCounts = {};
for (const artwork of allArtworks) {
  const coll = artwork.data.collection;
  if (!collectionCounts[coll]) collectionCounts[coll] = { total: 0, available: 0 };
  collectionCounts[coll].total++;
  if (artwork.data.status === 'Available') collectionCounts[coll].available++;
}
---

<BaseLayout title={title} description={description}>
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-display mb-6">{title}</h1>
    <p class="text-lg text-secondary leading-relaxed">
      Each series reveals a different emotional landscape — from city memories to hidden confessions, symbolic sketches and fragile flowers.
    </p>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {collections.map((col) => {
        const counts = collectionCounts[col.data.slug] || { total: 0, available: 0 };
        return (
          <a href={`/art/${col.data.slug}/`} class="group">
            <img
              src={normalizeImageUrl(col.data.cover_image || '')}
              alt={col.data.title}
              class="w-full h-auto rounded-sm mb-4 group-hover:opacity-90 transition-opacity"
              loading="lazy"
            />
            <h2 class="font-display text-xl mb-1 group-hover:text-accent transition-colors">{col.data.title}</h2>
            <p class="text-sm text-secondary mb-2">{col.data.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs text-secondary">{counts.total} works{counts.available > 0 && <span class="text-accent"> · {counts.available} available</span>}</span>
            </div>
            <span class="inline-block mt-3 text-sm font-medium text-accent hover:text-accent/80 transition-colors">
              View collection →
            </span>
          </a>
        );
      })}
    </div>

    <div class="mt-16 pt-8 border-t border-gray-200 text-center">
      <p class="text-secondary mb-4">Looking for a specific piece?</p>
      <a href="/contact/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">
        Contact the Artist
      </a>
    </div>
  </section>
</BaseLayout>
