---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Art Collections — Alena Mart';
const description = 'Explore the art collections by Alena Martsyanava — from city memories to hidden confessions, symbolic sketches and fragile flowers.';
const base = 'https://alenam.art/wp-content/uploads/';

const collections = [
  {
    slug: 'big-city-life',
    title: 'Big City Life',
    image: base + '2025/01/tramvai-alena.avif',
    description: 'Cities, memories and emotional landscapes.',
    works: 11,
    available: 2,
  },
  {
    slug: 'bits-and-pieces',
    title: 'Bits and Pieces',
    image: base + '2025/01/IMG_5841.avif',
    description: 'Small details, grand impressions, emotional traces.',
    works: 11,
    available: 0,
  },
  {
    slug: 'little-pleasures',
    title: 'Little Pleasures',
    image: base + '2025/01/IMG_5801.avif',
    description: 'Everyday objects turned into quiet joy.',
    works: 10,
    available: 1,
  },
  {
    slug: 'at-the-seaside',
    title: 'At the Seaside',
    image: base + '2025/01/IMG_5810.avif',
    description: 'Water as strength, peace and release.',
    works: 8,
    available: 0,
  },
  {
    slug: 'mind-games',
    title: 'Mind Games',
    image: base + '2025/01/IMG_5785.avif',
    description: 'Symbols, puzzles and hidden meanings.',
    works: 10,
    available: 0,
  },
  {
    slug: 'confessions-should-be-better-planned',
    title: 'Confessions should be better planned',
    image: base + '2025/01/IMG_5550-2-scaled.avif',
    description: 'Raw expression, masks, hidden emotions.',
    works: 12,
    available: 7,
  },
  {
    slug: 'flora',
    title: 'Flora',
    image: base + '2025/02/5330074966210769632.avif',
    description: 'Flowers, femininity, fragility and preserved memory.',
    works: 10,
    available: 2,
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-display mb-6">{title}</h1>
    <p class="text-lg text-secondary leading-relaxed">
      Each series reveals a different emotional landscape — from city memories to hidden confessions, symbolic sketches and fragile flowers.
    </p>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {collections.map((col) => (
        <a href={`/art/${col.slug}/`} class="group block">
          <img
            src={col.image}
            alt={col.title}
            class="w-full h-auto rounded-sm mb-4 group-hover:opacity-90 transition-opacity"
            loading="lazy"
          />
          <h2 class="font-display text-xl mb-1 group-hover:text-accent transition-colors">{col.title}</h2>
          <p class="text-sm text-secondary mb-2">{col.description}</p>
          <div class="flex items-center justify-between">
            <span class="text-xs text-secondary">{col.works} works{col.available > 0 && <span class="text-accent"> · {col.available} available</span>}</span>
          </div>
          <span class="inline-block mt-3 text-sm font-medium text-accent hover:text-accent/80 transition-colors">
            View collection →
          </span>
        </a>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-gray-200 text-center">
      <p class="text-secondary mb-4">Looking for a specific piece?</p>
      <a href="/contact/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">
        Contact the Artist
      </a>
    </div>
  </section>
</BaseLayout>
