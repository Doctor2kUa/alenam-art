---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { normalizeImageUrl } from '../../../lib/media';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { event: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const title = event.data.title;
---

<BaseLayout title={`${title} — Alena ART`} description={event.data.excerpt || ''}>
  <article class="pt-24 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/blog/" class="text-sm text-secondary hover:text-primary transition-colors mb-8 inline-block">← Back to Exhibitions</a>

      <!-- Cover image -->
      {event.data.cover_image && (
        <figure class="mb-8">
          <img
            src={normalizeImageUrl(event.data.cover_image)}
            alt={event.data.title}
            class="w-full h-auto rounded-sm"
          />
        </figure>
      )}

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-4">
        <time class="text-xs text-gray-400 uppercase tracking-wider">
          {new Date(event.data.event_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
        </time>
        {event.data.city && (
          <>
            <span class="text-xs text-gray-300">·</span>
            <span class="text-xs text-secondary">{event.data.city}</span>
          </>
        )}
        {event.data.venue && (
          <>
            <span class="text-xs text-gray-300">·</span>
            <span class="text-xs text-secondary">{event.data.venue}</span>
          </>
        )}
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-5xl font-display leading-tight mb-6">{event.data.title}</h1>

      <!-- Excerpt -->
      {event.data.excerpt && (
        <p class="text-lg text-secondary leading-relaxed mb-8">{event.data.excerpt}</p>
      )}

      <!-- Gallery -->
      {event.data.gallery && event.data.gallery.length > 0 && (
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-8">
          {event.data.gallery.map((img, i) => (
            <img
              key={i}
              src={normalizeImageUrl(img.image || '')}
              alt={`${event.data.title} - image ${i + 1}`}
              class="w-full h-auto rounded-sm"
              loading="lazy"
            />
          ))}
        </div>
      )}

      {/* Body content */}
      {event.body && (
        <div class="prose prose-lg max-w-none">
          <Fragment set:html={event.body} />
        </div>
      )}

      {/* Related collection */}
      {event.data.related_collection && (
        <div class="mt-12 pt-8 border-t border-gray-200">
          <p class="text-sm text-secondary mb-2">Related collection:</p>
          <a href={`/art/${event.data.related_collection}/`} class="text-sm font-medium text-accent hover:text-accent/80">
            {event.data.related_collection} →
          </a>
        </div>
      )}
    </div>
  </article>

  <!-- CTA -->
  <section class="py-16 bg-light text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-display mb-4">Interested in a work or collaboration?</h2>
      <p class="text-secondary mb-6">For exhibition proposals, commissions or partnerships, please get in touch.</p>
      <a href="/contact/" class="inline-block bg-primary text-white px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-primary/90 transition-colors">
        Contact the Artist
      </a>
    </div>
  </section>
</BaseLayout>
