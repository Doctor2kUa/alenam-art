---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Blog';
const description = 'Blog about art, exhibitions, and life by Alena Martsyanava.';
const base = 'https://alenam.art/wp-content/uploads/';

// Blog posts (Exhibitions category) - matching original order and images
const posts = [
  {
    slug: 'amazing-evening-amazing-place-amazing-people',
    title: 'Amazing evening, amazing place, amazing people!',
    date: '2025-06-01',
    image: base + '2025/06/Screenshot_2025-09-27_13-00-03.png',
    category: 'Exhibitions',
    excerpt: 'Thanks a million to @sante_praha for hosting my art collection "Confessions should be better planned", to @wine.you.prague for supporting my idea in all the ways, to @trambitskaya_photo for being my dearest content maker!!! And everyone who attended and keeps attending!',
  },
  {
    slug: 'a-presentation-of-the-art-collection-confessions-should-be-better-planned-by-alena-martsyanava',
    title: 'A presentation of the art collection "Confessions Should Be Better Planned" by Alena Martsyanava.',
    date: '2025-05-07',
    image: base + '2025/05/alena.avif',
    category: 'Exhibitions',
    excerpt: 'On the 23rd of May, a cozy place SANTE in Prague is welcoming the audience for a special event: A presentation of the art collection "Confessions Should Be Better Planned" by Alena Martsyanava.',
  },
  {
    slug: 'confessions-should-be-better-planned-1-0-in-warsaw',
    title: 'Confessions should be better planned 1.0 in Warsaw',
    date: '2025-03-02',
    image: base + '2025/03/photo_5334917533247075316_y-1.avif',
    category: 'Exhibitions',
    excerpt: 'On February 16, 2025, the art-beauty shop ALAR in Warsaw launched the first expo of Alena\'s collection "Confessions should be better planned". This time only 8 works from this very load of paintings were exhibited to the audience.',
  },
  {
    slug: 'taking-part-in-contro-la-violenza-sulle-donne-expo',
    title: 'Taking part in "Contro la Violenza sulle Donne" expo',
    date: '2025-01-03',
    image: base + '2025/01/photo_5458821030429715645_x.avif',
    category: 'Exhibitions',
    excerpt: 'So proud to have had a chance of participating in the event raising awareness of the domestic violence towards women in Italy. My artwork "oops I spilt the paint" organically fitted into the collection of works.',
  },
  {
    slug: 'auction-in-wroclaw-poland',
    title: 'Auction in Wroclaw, Poland',
    date: '2025-01-03',
    image: base + '2025/01/photo_5458821030429715635_y.avif',
    category: 'Exhibitions',
    excerpt: 'Alena\'s artwork in an unusual technique – Grattage – took part in the autcion organized by Students Artworks Foundation and was sold to the local art admirer.',
  },
  {
    slug: 'interpretation-of-moments-boys-vs-girls',
    title: 'Interpretation of moments: boys vs girls',
    date: '2024-12-15',
    image: base + '2025/01/photo_5458821030429715607_y.avif',
    category: 'Exhibitions',
    excerpt: 'Another join-fources-expo with a famous rock musician from Minsk — Eugene Buzouski — who happaned to reveal a great artistic talend and started his way as an artist.',
  },
  {
    slug: 'the-dream-on-expo',
    title: 'The "Dream on" Expo',
    date: '2024-12-10',
    image: base + '2025/01/photo_5458821030429715600_y.avif',
    category: 'Exhibitions',
    excerpt: 'The name of the exhibition was selected on purpose as it was the first time Alena had decided to introduce a new young talent to the world, joining creating fources with a girl.',
  },
  {
    slug: 'the-35-expo',
    title: 'The "35" Expo',
    date: '2024-12-05',
    image: base + '2025/01/photo_5458821030429715571_y.avif',
    category: 'Exhibitions',
    excerpt: 'This particular event was devited to Alena\'s 35th anniversary, which she decided to spend in an unusual company of the opening night visitors.',
  },
  {
    slug: 'сhaotic-still-life',
    title: 'Сhaotic still-life',
    date: '2024-11-27',
    image: base + '2025/01/photo_5458821030429715563_x.avif',
    category: 'Exhibitions',
    excerpt: 'Took place at the same venue in autumn 2014 while Alena was expecting her baby. Featuring mainly still-lives and moments of Alena\'s life.',
  },
  {
    slug: 'first-expo',
    title: 'First Expo',
    date: '2024-11-27',
    image: base + '2025/01/IMG_5665.avif',
    category: 'Exhibitions',
    excerpt: 'First Alena\'s Expo happened back in 2013 and had in the exposition 30 artworks. Featured by the local rock start performance at the opening.',
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-display mb-6">{title}</h1>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto pb-20">
    <ul class="space-y-0">
      {posts.map((post) => (
        <li class="py-8 border-b border-gray-200 last:border-b-0">
          <figure class="mb-4">
            <img
              src={post.image}
              alt={post.title}
              class="w-full h-auto rounded-sm"
              loading="lazy"
            />
          </figure>
          <div class="mb-2">
            <a href="/blog/" class="text-xs text-accent hover:text-accent/80 transition-colors">{post.category}</a>
          </div>
          <h2 class="text-2xl md:text-3xl font-display mb-4">
            <a href="/blog/" class="hover:text-accent transition-colors">{post.title}</a>
          </h2>
          <p class="text-secondary leading-relaxed mb-2">{post.excerpt}</p>
          <p>
            <a href="/blog/" class="text-sm font-medium text-accent hover:text-accent/80 transition-colors">Continue Reading</a>
          </p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
