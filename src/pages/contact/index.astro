---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Contact — Alena Mart';
const description = 'Get in touch with Alena Mart for available artworks, replicas, commissions, exhibitions or collaborations.';
---

<BaseLayout title={title} description={description}>
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-display mb-6">{title}</h1>
    <p class="text-lg text-secondary leading-relaxed">
      For available artworks, replicas, commissions, exhibitions or collaborations, send a request below.
    </p>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 max-w-2xl mx-auto pb-20">
    <!-- Request context from artwork -->
    <div id="request-context" class="hidden mb-6 p-4 bg-accent/5 border border-accent/20 rounded-sm">
      <p class="text-sm text-secondary">You are requesting price for:</p>
      <p id="request-artwork-name" class="text-base font-display text-primary mb-1"></p>
      <p class="text-sm text-secondary">
        Collection: <span id="request-collection-name"></span>
      </p>
    </div>

    <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-6">
      <input type="hidden" name="form-name" value="contact" />
      <p hidden aria-hidden="true" tabindex="-1">
        <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>

      <input type="hidden" name="artwork" id="artwork-field" value="" />
      <input type="hidden" name="collection" id="collection-field" value="" />

      <div>
        <label for="name" class="block text-sm font-medium text-primary mb-2">Name</label>
        <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-200 rounded-sm focus:outline-none focus:border-primary transition-colors" />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-primary mb-2">Email</label>
        <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-200 rounded-sm focus:outline-none focus:border-primary transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium text-primary mb-3">I am interested in:</label>
        <fieldset class="space-y-2">
          <legend class="sr-only">Interest</legend>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="radio" name="interest" value="buying" class="w-4 h-4 text-primary" />
            <span class="text-sm text-secondary">Buying an available artwork</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="radio" name="interest" value="replica" class="w-4 h-4 text-primary" />
            <span class="text-sm text-secondary">Ordering a replica</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="radio" name="interest" value="commission" class="w-4 h-4 text-primary" />
            <span class="text-sm text-secondary">Commissioning a new piece</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="radio" name="interest" value="exhibition" class="w-4 h-4 text-primary" />
            <span class="text-sm text-secondary">Exhibition / collaboration</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="radio" name="interest" value="general" class="w-4 h-4 text-primary" checked />
            <span class="text-sm text-secondary">General question</span>
          </label>
        </fieldset>
      </div>

      <div>
        <label for="subject" class="block text-sm font-medium text-primary mb-2">Subject</label>
        <input type="text" id="subject" name="subject" class="w-full px-4 py-3 border border-gray-200 rounded-sm focus:outline-none focus:border-primary transition-colors" />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-primary mb-2">Message</label>
        <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 border border-gray-200 rounded-sm focus:outline-none focus:border-primary transition-colors resize-none"></textarea>
      </div>

      <button type="submit" id="submit-btn" class="w-full bg-primary text-white px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-primary/90 transition-colors">
        Send request
      </button>

      <div id="form-feedback" class="hidden mt-4 text-center">
        <p id="form-success" class="hidden text-sm text-green-600">Thank you. Your request has been sent.</p>
        <p id="form-error" class="hidden text-sm text-red-600">Something went wrong. Please try again or email directly at <a href="mailto:alenam.art@gmail.com" class="underline">alenam.art@gmail.com</a>.</p>
        <p id="form-loading" class="hidden text-sm text-secondary">Sending...</p>
      </div>

      <p class="text-xs text-secondary text-center">Your message will be sent directly to the artist.</p>
    </form>

    <div class="mt-12 pt-8 border-t border-gray-200 text-center">
      <p class="text-sm text-secondary mb-2">Or reach directly:</p>
      <a href="mailto:alenam.art@gmail.com" class="text-sm font-medium text-accent hover:text-accent/80 transition-colors">alenam.art@gmail.com</a>
    </div>
  </section>

  <script>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var interest = params.get('interest');
      var artwork = params.get('artwork');
      var collection = params.get('collection');

      if (interest) {
        var radio = document.querySelector('input[name="interest"][value="' + interest + '"]');
        if (radio) {
          document.querySelectorAll('input[name="interest"]').forEach(function(r) { r.checked = false; });
          radio.checked = true;
        }
      }

      if (artwork) {
        var subjectField = document.getElementById('subject');
        if (subjectField) subjectField.value = 'Price request: ' + artwork;

        // Show request context block
        var requestContext = document.getElementById('request-context');
        var artworkName = document.getElementById('request-artwork-name');
        var collectionName = document.getElementById('request-collection-name');
        if (requestContext) requestContext.classList.remove('hidden');
        if (artworkName) artworkName.textContent = artwork;
        if (collectionName) collectionName.textContent = decodeURIComponent(collection || '');
      }

      if (collection) {
        var msgField = document.getElementById('message');
        // Message is already set in the artwork block above
        if (msgField && !msgField.value) {
          var artworkName2 = artwork || '';
          var prefix = 'Hello, I am interested in the artwork "' + artworkName2 + '"';
          if (collection) prefix += ' from the collection "' + collection + '"';
          prefix += '. Please send me price and availability details.';
          msgField.value = prefix;
        }
      }

      // Form submission handling
      var form = document.querySelector('form[name="contact"]');
      var submitBtn = document.getElementById('submit-btn');
      var formFeedback = document.getElementById('form-feedback');
      var formSuccess = document.getElementById('form-success');
      var formError = document.getElementById('form-error');
      var formLoading = document.getElementById('form-loading');

      if (form) {
        form.addEventListener('submit', function(e) {
          // Show loading state
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';
            submitBtn.classList.add('opacity-75');
          }
          if (formFeedback) formFeedback.classList.remove('hidden');
          if (formLoading) formLoading.classList.remove('hidden');

          // For Netlify Forms, we need to allow the form to submit normally
          // but show success/error feedback based on the response
          // Since Netlify handles the redirect, we'll use a timeout to show feedback
          setTimeout(function() {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Send request';
              submitBtn.classList.remove('opacity-75');
            }
          }, 3000);
        });
      }

      // Check for success/error in URL (Netlify redirects back with query params)
      var urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('success') === 'true') {
        if (formFeedback) formFeedback.classList.remove('hidden');
        if (formSuccess) formSuccess.classList.remove('hidden');
        if (form) form.style.display = 'none';
      }
      if (urlParams.get('error') === 'true') {
        if (formFeedback) formFeedback.classList.remove('hidden');
        if (formError) formError.classList.remove('hidden');
      }
    })();
  </script>
</BaseLayout>
