---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { normalizeImageUrl } from '../lib/media';

// Load site settings
const siteSettings = await getEntry('settings', 'site');
const siteTitle = siteSettings?.data?.site_title || 'Alena Mart — Contemporary Artist';
const siteDescription = siteSettings?.data?.site_description || '';

// Load home page content
const homePage = await getEntry('pages', 'home');
const heroTitle = homePage?.data?.hero_title || 'ART NEVER COMES FROM HAPPINESS';
const heroStatement = homePage?.data?.hero_statement || '';

// Load collections for display
const allCollections = await getCollection('art_collections');
const featuredCollections = allCollections
  .filter(c => c.data.featured_on_home)
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// Load available works for preview
const allArtworks = await getCollection('artworks');
const availableWorks = allArtworks
  .filter(a => a.data.status === 'Available')
  .slice(0, 6);

// Load upcoming events
const events = await getCollection('events');
const upcomingEvents = events
  .sort((a, b) => new Date(a.data.event_date).getTime() - new Date(b.data.event_date).getTime())
  .slice(0, 3);
---

<BaseLayout title={siteTitle} description={siteDescription}>
  <!-- Hero Cover -->
  <section class="relative h-[80vh] min-h-[500px] flex items-center justify-center overflow-hidden bg-[#3d3636]">
    <img
      src={normalizeImageUrl(siteSettings?.data?.og_image || 'uploads/2024/12/alena-mart-1.avif')}
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-position-bottom opacity-60"
    />
    <div class="relative z-10 text-center max-w-4xl mx-auto px-4">
      <p class="text-white/70 text-sm uppercase tracking-widest mb-4">{siteSettings?.data?.artist_name || 'Alena Mart'}</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display text-white mb-6">
        {heroTitle}
      </h1>
      {heroStatement && (
        <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed mb-8">
          {heroStatement}
        </p>
      )}
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/art/" class="inline-block bg-white text-primary px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-white/90 transition-colors">
          View Collections
        </a>
        <a href="/art/available/" class="inline-block border border-white text-white px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-white/10 transition-colors">
          Available Works
        </a>
        <a href="/contact/" class="inline-block border border-white text-white px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-white/10 transition-colors">
          Contact the Artist
        </a>
      </div>
    </div>
  </section>

  <!-- MY ART section with images -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
    <h2 class="text-sm uppercase tracking-[0.3em] text-center text-secondary mb-4">My Art</h2>
    <p class="text-xl md:text-2xl text-center max-w-3xl mx-auto mb-12 leading-relaxed">
      Art is the magic glue that is capable of sticking a broken heart back together and filling it with hope and love
    </p>

    <!-- 2x2 Grid of images -->
    <div class="grid grid-cols-2 gap-4 mb-8">
      <img src={normalizeImageUrl('uploads/2024/12/4.avif')} alt="Abstract painting by Alena Mart" class="w-full h-auto rounded-sm" loading="lazy" />
      <img src={normalizeImageUrl('uploads/2024/12/3.avif')} alt="Abstract painting by Alena Mart" class="w-full h-auto rounded-sm" loading="lazy" />
      <img src={normalizeImageUrl('uploads/2024/12/tramvai-alena.avif')} alt="City tram painting by Alena Mart" class="w-full h-auto rounded-sm" loading="lazy" />
      <img src={normalizeImageUrl('uploads/2024/12/photo_5262762490696168254_y-1.avif')} alt="Art exhibition by Alena Mart" class="w-full h-auto rounded-sm" loading="lazy" />
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- COLLECTIONS section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
    <h2 class="text-sm uppercase tracking-[0.3em] text-center text-secondary mb-10">Collections</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredCollections.map((col) => (
        <a href={`/art/${col.data.slug}/`} class="group">
          <img
            src={normalizeImageUrl(col.data.cover_image || '')}
            alt={col.data.title}
            class="w-full h-auto rounded-sm mb-4 group-hover:opacity-90 transition-opacity"
            loading="lazy"
          />
          <h3 class="font-display text-lg">{col.data.title}</h3>
        </a>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/art/" class="inline-block border border-primary text-primary px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-primary hover:text-white transition-colors">
        View All Collections
      </a>
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- AVAILABLE WORKS section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
    <h2 class="text-sm uppercase tracking-[0.3em] text-center text-secondary mb-10">Available Works</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {availableWorks.map((work) => (
        <a href={`/art/${work.data.collection}/${work.data.slug}/`} class="group">
          <figure class="m-0 mb-3">
            <img
              src={normalizeImageUrl(work.data.image || '')}
              alt={work.data.name}
              class="w-full h-auto rounded-sm group-hover:opacity-90 transition-opacity"
              loading="lazy"
            />
          </figure>
          <h3 class="font-display text-base mb-1">{work.data.name}</h3>
          <p class="text-xs text-secondary">{work.data.technique} · {work.data.size} · {work.data.year}</p>
        </a>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/art/available/" class="inline-block border border-primary text-primary px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-primary hover:text-white transition-colors">
        View All Available Works
      </a>
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- EXHIBITIONS & EVENTS section -->
  {upcomingEvents.length > 0 && (
    <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
      <h2 class="text-sm uppercase tracking-[0.3em] text-center text-secondary mb-10">Exhibitions & Events</h2>
      <div class="space-y-8">
        {upcomingEvents.map((event) => (
          <div class="border-b border-gray-200 pb-8 last:border-b-0">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-3">
              <time class="text-xs text-gray-400 uppercase tracking-wider">
                {new Date(event.data.event_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
              </time>
              {event.data.city && (
                <>
                  <span class="text-xs text-gray-300">·</span>
                  <span class="text-xs text-secondary">{event.data.city}</span>
                </>
              )}
              {event.data.venue && (
                <>
                  <span class="text-xs text-gray-300">·</span>
                  <span class="text-xs text-secondary">{event.data.venue}</span>
                </>
              )}
            </div>
            <h3 class="font-display text-xl mb-2">{event.data.title}</h3>
            {event.data.excerpt && (
              <p className="text-sm text-secondary">{event.data.excerpt}</p>
            )}
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/blog/" class="inline-block text-sm font-medium text-accent hover:text-accent/80 transition-colors">
          View Exhibitions →
        </a>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 bg-light text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-display mb-4">Interested in a work?</h2>
      <p class="text-secondary mb-6">If you wish to buy Alena's works or invite her to an exhibition, please get in touch.</p>
      <a href="/contact/" class="inline-block bg-primary text-white px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-primary/90 transition-colors">
        Contact the Artist
      </a>
    </div>
  </section>
</BaseLayout>
