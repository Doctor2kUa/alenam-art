---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Art Never Comes From Happiness';
const description = 'Alena Martsyanava — indie artist from Eastern Europe. Art never comes from happiness.';
const base = 'https://alenam.art/wp-content/uploads/';
---

<BaseLayout title={title} description={description}>
  <!-- Hero Cover -->
  <section class="relative h-[80vh] min-h-[500px] flex items-center justify-center overflow-hidden bg-[#3d3636]">
    <img
      src={base + "2024/12/alena-mart-1.avif"}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-60"
    />
    <div class="relative z-10 text-center max-w-4xl mx-auto px-4">
      <p class="text-white/70 text-sm uppercase tracking-widest mb-4">Alena Mart</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display text-white mb-6">
        ART NEVER COMES FROM HAPPINESS
      </h1>
      <p class="text-white/80 text-lg md:text-xl mb-8 max-w-2xl mx-auto">
        Contemporary artist exploring memory, trauma, tenderness and distorted reality.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/art/" class="inline-block bg-white text-primary px-6 py-3 text-sm uppercase tracking-wider font-medium hover:bg-white/90 transition-colors">
          Explore Collections
        </a>
        <a href="/contact/" class="inline-block border border-white text-white px-6 py-3 text-sm uppercase tracking-wider font-medium hover:bg-white/10 transition-colors">
          Contact the Artist
        </a>
      </div>
    </div>
  </section>

  <!-- MY ART section -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-sm uppercase tracking-[0.3em] text-secondary mb-4">My Art</h2>
      <h3 class="text-2xl md:text-3xl font-display leading-relaxed mb-4">
        Art is the magic glue that is capable of sticking a broken heart back together and filling it with hope and love
      </h3>
      <p class="text-secondary leading-relaxed max-w-2xl mx-auto">
        Alena's work turns emotional tension, memories and fragile moments into expressive visual stories.
      </p>
    </div>

    <!-- Art images grid -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <img src={base + "2024/12/4.avif"} alt="Alena artwork" class="w-full h-auto rounded-sm" loading="lazy" />
        <img src={base + "2024/12/3.avif"} alt="Alena artwork" class="w-full h-auto rounded-sm" loading="lazy" />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <img src={base + "2024/12/tramvai-alena.avif"} alt="Alena artwork" class="w-full h-auto rounded-sm" loading="lazy" />
        <img src={base + "2024/12/photo_5262762490696168254_y-1.avif"} alt="Alena artwork" class="w-full h-auto rounded-sm" loading="lazy" />
      </div>
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- COLLECTIONS section -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-sm uppercase tracking-[0.3em] text-secondary mb-8 text-center">Collections</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <a href="/art/big-city-life/" class="block">
            <img src={base + "2025/01/tramvai-alena.avif"} alt="Big City Life" class="w-full h-auto rounded-sm mb-4" loading="lazy" />
          </a>
          <h3 class="font-display text-lg text-center mb-2">
            <a href="/art/big-city-life/" class="hover:text-accent transition-colors">Big City Life</a>
          </h3>
          <p class="text-sm text-secondary text-center">Cities, memories and emotional landscapes.</p>
        </div>

        <div>
          <a href="/art/bits-and-pieces/" class="block">
            <img src={base + "2025/01/IMG_5841.avif"} alt="Bits and Pieces" class="w-full h-auto rounded-sm mb-4" loading="lazy" />
          </a>
          <h3 class="font-display text-lg text-center mb-2">
            <a href="/art/bits-and-pieces/" class="hover:text-accent transition-colors">Bits and Pieces</a>
          </h3>
          <p class="text-sm text-secondary text-center">Small details, grand impressions, emotional traces.</p>
        </div>

        <div>
          <a href="/art/little-pleasures/" class="block">
            <img src={base + "2025/01/IMG_5801.avif"} alt="Little Pleasures" class="w-full h-auto rounded-sm mb-4" loading="lazy" />
          </a>
          <h3 class="font-display text-lg text-center mb-2">
            <a href="/art/little-pleasures/" class="hover:text-accent transition-colors">Little Pleasures</a>
          </h3>
          <p class="text-sm text-secondary text-center">Everyday objects turned into quiet joy.</p>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="/art/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">
          View All Collections
        </a>
      </div>
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- AVAILABLE WORKS section -->
  <section class="py-16 bg-light">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-sm uppercase tracking-[0.3em] text-secondary mb-4 text-center">Available Works</h2>
      <p class="text-center text-secondary mb-8 max-w-2xl mx-auto">Selected artworks currently available for purchase.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
      <img src={base + "2025/01/IMG_5567-669x1024.avif"} alt="Gone" class="w-full h-auto rounded-sm mb-4" loading="lazy" />
      <h3 class="font-display text-lg mb-1">Gone</h3>
      <p class="text-sm text-secondary">Acrylic on canvas · 40×60 cm · 2022</p>
      <p class="text-sm text-accent font-medium mt-1">Available</p>
    </div>
    <div>
      <img src={base + "2025/01/IMG_5560-1012x1024.avif"} alt="Disconnect" class="w-full h-auto rounded-sm mb-4" loading="lazy" />
      <h3 class="font-display text-lg mb-1">Disconnect</h3>
      <p class="text-sm text-secondary">Acrylic on canvas · 50×70 cm · 2024</p>
      <p class="text-sm text-accent font-medium mt-1">Available</p>
    </div>
    <div>
      <img src={base + "2025/01/IMG_5556-786x1024.avif"} alt="Apple" class="w-full h-auto rounded-sm mb-4" loading="lazy" />
      <h3 class="font-display text-lg mb-1">Apple</h3>
      <p class="text-sm text-secondary">Acrylic on canvas · 100×70 cm · 2022</p>
      <p class="text-sm text-accent font-medium mt-1">Available</p>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="/art/available/" class="inline-block text-sm font-medium uppercase tracking-wider hover:text-accent transition-colors border-b border-current pb-0.5">
          View All Available Works
        </a>
      </div>
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- Exhibitions & Events -->
  <section class="py-16 text-center">
    <h2 class="text-sm uppercase tracking-[0.3em] text-secondary mb-4">Exhibitions & Events</h2>
    <p class="text-secondary mb-6 max-w-2xl mx-auto">Recent presentations, auctions and exhibitions.</p>
    <a href="/blog/" class="font-display text-xl hover:text-accent transition-colors">View Exhibitions</a>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-display mb-6">Interested in a work?</h2>
      <p class="text-white/70 text-lg mb-8">
        If you wish to buy Alena's works, order a replica, or discuss a collaboration, please get in touch.
      </p>
      <a href="/contact/" class="inline-block bg-white text-primary px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-white/90 transition-colors">
        Contact the Artist
      </a>
    </div>
  </section>
</BaseLayout>
