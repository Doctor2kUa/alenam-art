---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Story';
const description = 'Artist biography and personal story of Alena Martsyanava — contemporary artist exploring memory, trauma, tenderness and emotional transformation.';
const base = 'https://alenam.art/wp-content/uploads/';
---

<BaseLayout title={title} description={description}>
  <!-- Hero (full-width image) -->
  <section class="relative w-full">
    <img
      src={base + '2024/12/alena-mart-1.avif'}
      alt="Alena Martsyanava"
      class="w-full h-auto object-cover max-h-[80vh]"
    />
    <div class="absolute inset-0 flex items-center justify-center bg-black/20">
      <h1 class="text-4xl md:text-6xl font-display text-white text-center px-4">ART NEVER COMES FROM HAPPINESS</h1>
    </div>
  </section>

  <!-- MY ART section with images -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
    <h2 class="text-sm uppercase tracking-[0.3em] text-center text-secondary mb-4">My Art</h2>
    <p class="text-xl md:text-2xl text-center max-w-3xl mx-auto mb-12 leading-relaxed">
      Art is the magic glue that is capable of sticking a broken heart back together and filling it with hope and love
    </p>

    <!-- 2x2 Grid of images -->
    <div class="grid grid-cols-2 gap-4 mb-8">
      <img src={base + '2024/12/4.avif'} alt="Alena artwork" class="w-full h-auto rounded-sm" loading="lazy" />
      <img src={base + '2024/12/3.avif'} alt="Alena artwork" class="w-full h-auto rounded-sm" loading="lazy" />
      <img src={base + '2024/12/tramvai-alena.avif'} alt="Alena artwork" class="w-full h-auto rounded-sm" loading="lazy" />
      <img src={base + '2024/12/photo_5262762490696168254_y-1.avif'} alt="Alena artwork" class="w-full h-auto rounded-sm" loading="lazy" />
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- Artist Statement -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h2 class="text-sm uppercase tracking-[0.3em] text-secondary mb-6">Artist Statement</h2>
    <div class="prose prose-lg max-w-none">
      <p class="text-secondary leading-relaxed mb-4">
        Art never comes from happiness. It comes from the need to process what life puts you through — the memories that won't let go, the emotions too intense to stay inside, the moments that break you and somehow make you whole again.
      </p>
      <p class="text-secondary leading-relaxed mb-4">
        My work is about emotional truth. I paint what I feel, not what I see. Cities, flowers, faces, objects — they all become vessels for something deeper: the weight of memory, the fragility of tenderness, the chaos of communication, the quiet strength of survival.
      </p>
      <p class="text-secondary leading-relaxed">
        Each collection is a chapter. Each piece is a confession I didn't know how to say out loud.
      </p>
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- Biography -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h2 class="text-sm uppercase tracking-[0.3em] text-secondary mb-6">Biography</h2>
    <div class="prose prose-lg max-w-none">
      <p class="text-secondary leading-relaxed mb-4">
        Alena Mart is a contemporary artist from Eastern Europe whose work explores the complex terrain of human emotion through painting, drawing and mixed media.
      </p>
      <p class="text-secondary leading-relaxed mb-4">
        Her artistic journey began in 2013 with her first exhibition in Minsk, featuring 30 works and attracting over a thousand visitors. Since then, she has developed a distinctive visual language that transforms personal experience into universal emotional statements.
      </p>
      <p class="text-secondary leading-relaxed mb-4">
        Alena's work has been presented in exhibitions across Europe, including shows in Warsaw, Prague, Wroclaw and Italy. Her pieces are held in private collections internationally.
      </p>
      <p class="text-secondary leading-relaxed">
        She works across multiple techniques — from oil painting and acrylics to pastels, gouache and the experimental grattage technique.
      </p>
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- Collections preview -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
    <h2 class="text-sm uppercase tracking-[0.3em] text-center text-secondary mb-10">Collections</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <a href="/art/big-city-life/" class="group">
        <img src={base + '2025/01/tramvai-alena.avif'} alt="Big City Life" class="w-full h-auto rounded-sm mb-4 group-hover:opacity-90 transition-opacity" loading="lazy" />
        <h3 class="font-display text-lg">Big City Life</h3>
      </a>
      <a href="/art/bits-and-pieces/" class="group">
        <img src={base + '2025/01/IMG_5841.avif'} alt="Bits and Pieces" class="w-full h-auto rounded-sm mb-4 group-hover:opacity-90 transition-opacity" loading="lazy" />
        <h3 class="font-display text-lg">Bits and Pieces</h3>
      </a>
      <a href="/art/little-pleasures/" class="group">
        <img src={base + '2025/01/IMG_5801.avif'} alt="Little Pleasures" class="w-full h-auto rounded-sm mb-4 group-hover:opacity-90 transition-opacity" loading="lazy" />
        <h3 class="font-display text-lg">Little Pleasures</h3>
      </a>
    </div>
    <div class="text-center mt-10">
      <a href="/art/" class="inline-block border border-primary text-primary px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-primary hover:text-white transition-colors">
        View All Collections
      </a>
    </div>
  </section>

  <hr class="border-gray-200 max-w-4xl mx-auto" />

  <!-- Exhibitions & Recognition -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h2 class="text-sm uppercase tracking-[0.3em] text-secondary mb-6">Exhibitions & Recognition</h2>
    <ul class="space-y-4">
      <li class="flex items-start gap-3">
        <span class="text-accent mt-1">•</span>
        <div>
          <h3 class="font-display text-base">First Expo — Minsk, 2013</h3>
          <p class="text-sm text-secondary">Debut exhibition with 30 artworks, attended by over 1,000 visitors</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent mt-1">•</span>
        <div>
          <h3 class="font-display text-base">The "35" Expo — Minsk, 2018</h3>
          <p class="text-sm text-secondary">Anniversary exhibition featuring exactly 35 works with live performance by Stary Olsa band</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent mt-1">•</span>
        <div>
          <h3 class="font-display text-base">Auction in Wroclaw, Poland</h3>
          <p class="text-sm text-secondary">Grattage work sold at auction organized by Students Artworks Foundation</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent mt-1">•</span>
        <div>
          <h3 class="font-display text-base">"Contro la Violenza sulle Donne" — Italy</h3>
          <p class="text-sm text-secondary">Participation in exhibition raising awareness about domestic violence</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent mt-1">•</span>
        <div>
          <h3 class="font-display text-base">Confessions in Warsaw — 2025</h3>
          <p class="text-sm text-secondary">First exhibition of the "Confessions" collection at ALAR art-beauty shop</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent mt-1">•</span>
        <div>
          <h3 class="font-display text-base">Presentation in Prague — 2025</h3>
          <p class="text-sm text-secondary">Collection presentation at SANTE Prague with live music and community</p>
        </div>
      </li>
    </ul>
  </section>

  <!-- Trust Block -->
  <section class="py-16 bg-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-secondary text-sm uppercase tracking-widest">
        Works in private collections · Exhibitions across Europe · Original paintings available · Open for collaborations
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-display mb-4">Interested in a work or collaboration?</h2>
      <p class="text-secondary mb-6">For available artworks, replicas, commissions or exhibition proposals, please get in touch.</p>
      <a href="/contact/" class="inline-block bg-primary text-white px-8 py-3 text-sm uppercase tracking-wider font-medium hover:bg-primary/90 transition-colors">
        Contact the Artist
      </a>
    </div>
  </section>
</BaseLayout>
